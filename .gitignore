# Build intermediates
Source/**/obj/
Source/**/bin/
*.user

# Never commit game / Harmony assemblies (referenced from the local install)
**/Assembly-CSharp.dll
**/UnityEngine*.dll
**/0Harmony.dll

# Compiled output IS shipped with the mod, so keep it tracked:
!1.6/Assemblies/RimDoctor.dll

# macOS cruft
.DS_Store

# RimDoctor runtime artifacts (generated in the game's mod dir at runtime)
Backups/
Logs/

# Local Claude Code settings
.claude/

# Generated clean-release staging (rebuild with tools/make_release.sh)
/release/

# Mac helper app: keep the SOURCE (.swift, build_app.sh), ignore generated artifacts
tools/app/*.app/
tools/app/AppIcon.icns
tools/app/AppIcon.iconset/
tools/app/icon_1024.png
tools/app/make_icon
tools/app/make_preview
tools/app/RimDoctorRepair

# Release archives (attached to GitHub releases, not tracked)
/RimDoctor-*.zip
